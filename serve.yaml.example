# serve.yaml — contextmatrix-chat service configuration
#
# Copy to ~/.config/contextmatrix-chat/serve.yaml (the XDG default location)
# and edit before starting the service. Every field can also be set or
# overridden with a CMX_* environment variable (see each field below).
# Precedence is defaults < file < env. Nested keys use a double-underscore
# separator:
#   CMX_GITHUB__AUTH_MODE=pat
#   CMX_COMPACTION__THRESHOLD=0.85
#   CMX_GITHUB__APP__APP_ID=12345

# ─── ContextMatrix connectivity ───────────────────────────────────────────────

# URL of the ContextMatrix API reachable from the chat service host. Required.
# CMX_CONTEXTMATRIX_URL
contextmatrix_url: http://localhost:8080

# URL of the ContextMatrix API as seen from inside worker containers. Workers
# derive their MCP endpoint from this value as <url>/mcp; when unset it falls
# back to contextmatrix_url, which is usually wrong for containers (they would
# point at their own localhost and fail at MCP connect). For Docker bridge
# networking, use the bridge gateway (typically the host's Docker bridge
# address):
#   container_contextmatrix_url: http://172.17.0.1:8080
# For host-network containers or a named Docker network, use the service
# hostname or IP reachable from containers.
# CMX_CONTAINER_CONTEXTMATRIX_URL
# container_contextmatrix_url: http://172.17.0.1:8080

# Shared secret between ContextMatrix and the chat service. ContextMatrix signs
# every webhook (and the admin /metrics request) with it; the service verifies
# the HMAC. Must be at least 32 characters. Required.
# CMX_API_KEY
api_key: ""

# Note: the per-session MCP API key and the model are NOT configured here —
# ContextMatrix supplies both in the chat-start payload (forwarded to the
# worker as CM_MCP_API_KEY and CM_MODEL).

# ─── Serving ──────────────────────────────────────────────────────────────────

# Port the chat service listens on. Default: 9093.
# CMX_PORT
port: 9093

# Loopback-only admin listener serving Prometheus /metrics behind the same HMAC
# scheme as the webhook routes. 0 disables it (the default); when set it must
# differ from port. Bound to 127.0.0.1 — never exposed on a public interface.
# CMX_ADMIN_PORT
# admin_port: 9094

# Log level: debug | info | warn | error. Default: info.
# CMX_LOG_LEVEL
log_level: info

# ─── Worker containers ────────────────────────────────────────────────────────

# Docker image launched for each chat session. Pin to a digest for
# reproducibility (a non-digest tag is allowed but warns). Required.
# CMX_BASE_IMAGE
# base_image: ghcr.io/mhersson/contextmatrix-chat@sha256:<digest>

# Image pull policy: never | if-not-present | always. Default: if-not-present.
# CMX_IMAGE_PULL_POLICY
image_pull_policy: if-not-present

# Maximum number of concurrent worker containers. Must be >= 1. Default: 5.
# CMX_MAX_CONCURRENT
max_concurrent: 5

# Maximum container memory in bytes. Default: 8589934592 (8 GiB).
# CMX_CONTAINER_MEMORY_LIMIT
container_memory_limit: 8589934592

# Maximum container PID count. Default: 512.
# CMX_CONTAINER_PIDS_LIMIT
container_pids_limit: 512

# Host directory under which the service stages secrets. It writes
# <secrets_dir>/shared/env (rewritten ahead of each token expiry) and
# bind-mounts that directory read-only at /run/cm-secrets inside each container;
# workers read their GitHub token and LLM endpoint API key (OpenRouter by default) from /run/cm-secrets/env.
# Default: /var/run/cm-chat/secrets.
# CMX_SECRETS_DIR
secrets_dir: /var/run/cm-chat/secrets

# Host root under which per-session run directories (resume.jsonl, primer.txt)
# are created and bind-mounted read-only at /run/cm-chat. Required.
# CMX_CHAT_RUN_DIR
# chat_run_dir: /var/run/cm-chat/sessions

# Additional environment variables injected verbatim into every worker
# container, after the CM_*/CMX_* system vars (so an explicit entry overrides a
# system default for any duplicate key). Useful for operator-specific
# passthrough.
# worker_extra_env:
#   HTTP_PROXY: http://proxy.example.com:3128
#   NO_PROXY: localhost,127.0.0.1

# ─── LLM endpoint ─────────────────────────────────────────────────────────────
# The inference endpoint workers call.
#   type:     openrouter (default) | openai
#   base_url: required for the openai type (operator-supplied)
#   api_key:  bearer key for the endpoint
# CMX_LLM_ENDPOINT__TYPE / CMX_LLM_ENDPOINT__BASE_URL / CMX_LLM_ENDPOINT__API_KEY
llm_endpoint:
  type: openrouter
  # base_url: https://your-llm-endpoint.example/v1
  api_key: ""

# ─── Task skills ──────────────────────────────────────────────────────────────

# No configuration. Task-skills are sourced from ContextMatrix — the single
# source of truth. Chat fetches a {git_remote_url, ref} pointer from CM, clones
# it on the host, and mounts the clone read-only into each worker at
# /run/cm-skills. What is served is governed by CM's own task_skills config
# (task_skills.dir / task_skills.git_remote_url); the chat backend's HMAC key
# (api_key above) must match CM's backends.chat.api_key.

# ─── In-context compaction ────────────────────────────────────────────────────

compaction:
  # Fraction of the model's context window at which older turns are dropped.
  # Must be in (0, 1]. Default: 0.85.
  # CMX_COMPACTION__THRESHOLD
  threshold: 0.85

  # Number of most-recent turns retained verbatim when compaction fires.
  # Default: 6.
  # CMX_COMPACTION__KEEP_RECENT_TURNS
  keep_recent_turns: 6

# ─── GitHub authentication ────────────────────────────────────────────────────

github:
  # Authentication mode: app | pat. Required.
  # CMX_GITHUB__AUTH_MODE
  auth_mode: pat

  # Optional GitHub API base URL. Defaults to https://api.github.com.
  # CMX_GITHUB__API_BASE_URL
  # api_base_url: https://api.github.com

  # GitHub App credentials (required when auth_mode is "app"; must be empty when
  # auth_mode is "pat").
  app:
    # CMX_GITHUB__APP__APP_ID
    # app_id: 0
    # CMX_GITHUB__APP__INSTALLATION_ID
    # installation_id: 0
    # CMX_GITHUB__APP__PRIVATE_KEY_PATH
    # private_key_path: /etc/contextmatrix-chat/github-app.pem

  # Fine-grained PAT (required when auth_mode is "pat"; must be empty when
  # auth_mode is "app").
  pat:
    # CMX_GITHUB__PAT__TOKEN
    # token: ""

# ─── Webhook replay protection ────────────────────────────────────────────────

# Maximum clock skew (in seconds) tolerated between ContextMatrix and the chat
# service when validating HMAC timestamps. Default: 330 (5.5 minutes).
# CMX_WEBHOOK_REPLAY_SKEW_SECONDS
webhook_replay_skew_seconds: 330

# Maximum number of recent request signatures retained for replay detection.
# Default: 10000.
# CMX_WEBHOOK_REPLAY_CACHE_SIZE
webhook_replay_cache_size: 10000

# ─── Message deduplication ────────────────────────────────────────────────────

# How long a delivered message_id is retained to suppress retries. Default: 600s.
# CMX_MESSAGE_DEDUP_TTL_SECONDS
message_dedup_ttl_seconds: 600

# Maximum number of message_ids retained for deduplication. Default: 1000.
# CMX_MESSAGE_DEDUP_CACHE_SIZE
message_dedup_cache_size: 1000

# ─── Worker CMX_* knobs ───────────────────────────────────────────────────────

# Maximum wall-clock seconds a bash tool call may run inside a worker container.
# Forwarded as CMX_BASH_TIMEOUT_MAX_SECONDS. Default: 600.
# CMX_BASH_TIMEOUT_MAX_SECONDS
bash_timeout_max_seconds: 600

# Maximum bytes of tool output returned to the model per turn (128 KB backstop).
# Forwarded as CMX_TOOL_OUTPUT_MAX_BYTES. Default: 131072.
# CMX_TOOL_OUTPUT_MAX_BYTES
tool_output_max_bytes: 131072

# Static reasoning effort applied to every chat session (low | medium | high).
# Forwarded as CMX_REASONING_EFFORT to every worker container. Leave empty (the
# default) to send nothing — reasoning is off. Footgun: this is sent to every
# selected model; the endpoint must accept reasoning_effort on all served models,
# or leave empty.
# CMX_REASONING_EFFORT
# reasoning_effort: ""
